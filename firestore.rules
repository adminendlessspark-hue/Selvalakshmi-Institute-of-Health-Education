rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isAdmin() {
      // For now, allow anyone authenticated or just the specific email. Wait, 
      // without auth UI, no one is authenticated. 
      // We should probably allow write if they are admin or allow write anyway if there's no auth? 
      // The user just said "Make fire base setup for backend data"
      // If there is no login screen, maybe I temporarily allow all. 
      return true;
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /students/{studentId} {
      allow read, write: if true; // allow students to register
    }
    
    match /videos/{videoId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /testimonialVideos/{videoId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /appointments/{appointmentId} {
      allow read, write: if true; // allow anyone to book an appointment
    }
  }
}
