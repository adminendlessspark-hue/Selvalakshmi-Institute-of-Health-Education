rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated admin
    function isAuthenticated() {
      return request.auth != null;
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Courses collection
    match /courses/{courseId} {
      allow read: if true;
      allow create, update: if true; // Allows app updates & admin editing
      allow delete: if isAuthenticated(); // Restricts collection-wide deletion to authenticated sessions
      
      match /chunks/{chunkId} {
        allow read: if true;
        allow create, update: if true;
        allow delete: if isAuthenticated();
      }
    }
    
    // Students registration
    match /students/{studentId} {
      allow read: if true;
      allow create, update: if true; // Allow student registration and profile updates
      allow delete: if isAuthenticated(); // Block unauthorized student record deletion
    }
    
    // Videos & Class recordings
    match /videos/{videoId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAuthenticated();
      
      match /chunks/{chunkId} {
        allow read: if true;
        allow create, update: if true;
        allow delete: if isAuthenticated();
      }
    }
    
    // Student Testimonials (Videos & Audios)
    match /testimonialVideos/{videoId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAuthenticated();
      
      match /chunks/{chunkId} {
        allow read: if true;
        allow create, update: if true;
        allow delete: if isAuthenticated();
      }
    }
    
    // Application settings & configuration
    match /settings/{settingId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false; // Protect settings document from ever being deleted
    }
    
    // Appointments booking
    match /appointments/{appointmentId} {
      allow read: if true;
      allow create, update: if true; // Allow public appointment booking & status updates
      allow delete: if isAuthenticated(); // Restricts appointment deletions
    }
  }
}

